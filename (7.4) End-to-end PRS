get_usable_covars <- function(data, covars, label) {
  miss_tbl <- data.frame(
    var          = covars,
    n_missing    = sapply(covars, function(v) sum(is.na(data[[v]]))),
    n_nonmissing = sapply(covars, function(v) sum(!is.na(data[[v]])))
  )
  miss_tbl <- miss_tbl[order(miss_tbl$n_nonmissing), ]
  cat("\nMissingness table for", label, ":\n")
  print(miss_tbl)
  drop_vars <- subset(miss_tbl, n_nonmissing == 0)$var
  if (length(drop_vars) > 0) {
    cat("Dropping all-NA covariates:", paste(drop_vars, collapse = ", "), "\n")
  }
  setdiff(covars, drop_vars)
}

fit_weighted_lm_robust <- function(formula, data, wvar = "w_att") {
  data <- data %>% mutate(.w_att_tmp = .data[[wvar]])
  fit  <- lm(formula, data = data, weights = .w_att_tmp)
  vc   <- sandwich::vcovHC(fit, type = "HC1")
  ct   <- lmtest::coeftest(fit, vcov. = vc)
  list(fit = fit, vcov = vc, coeftest = ct)
}

tidy_coeftest <- function(ct) {
  m   <- as.matrix(unclass(ct))
  out <- as.data.frame(m, stringsAsFactors = FALSE)
  if (ncol(out) >= 1) names(out)[1] <- "estimate"
  if (ncol(out) >= 2) names(out)[2] <- "std_error"
  if (ncol(out) >= 3) names(out)[3] <- "statistic"
  if (ncol(out) >= 4) names(out)[4] <- "p_value"
  out$term <- rownames(m)
  rownames(out) <- NULL
  tibble::as_tibble(out)
}

compute_vif <- function(fit_obj, label) {
  tryCatch({
    alias_info    <- alias(fit_obj$fit)
    aliased_terms <- rownames(alias_info$Complete)
    if (length(aliased_terms) > 0) {
      cat("\nAliased terms detected in", label, "— dropping before VIF:\n")
      cat(paste(aliased_terms, collapse = ", "), "\n")
      original_formula <- formula(fit_obj$fit)
      all_terms        <- attr(terms(original_formula), "term.labels")
      clean_terms      <- setdiff(all_terms, aliased_terms)
      response         <- as.character(original_formula[[2]])
      clean_formula    <- as.formula(paste(response, "~", paste(clean_terms, collapse = " + ")))
      clean_data       <- fit_obj$fit$model
      clean_data$.w    <- fit_obj$fit$weights
      clean_fit        <- lm(clean_formula, data = clean_data, weights = .w)
    } else {
      clean_fit <- fit_obj$fit
    }
    vif_vals <- car::vif(clean_fit)
    if (is.matrix(vif_vals)) {
      vif_out <- data.frame(term = rownames(vif_vals),
                            vif  = vif_vals[, "GVIF^(1/(2*Df))"]^2,
                            label = label, stringsAsFactors = FALSE)
    } else {
      vif_out <- data.frame(term = names(vif_vals),
                            vif  = as.numeric(vif_vals),
                            label = label, stringsAsFactors = FALSE)
    }
    vif_out <- vif_out[order(-vif_out$vif), ]
    cat("\nVIF diagnostics for", label, ":\n"); print(vif_out)
    vif_out
  }, error = function(e) {
    cat("\nVIF could not be computed for", label, ":", conditionMessage(e), "\n"); NULL
  })
}

